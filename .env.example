# Better Auth
BETTER_AUTH_SECRET=replace_with_a_random_32_plus_char_secret
BETTER_AUTH_URL=http://localhost:3000

# Neon / Vercel Postgres
# Pooled connection (recommended default)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Direct (unpooled) connection for tooling that needs it
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Optional aliases used by Vercel integrations
# POSTGRES_URL=postgresql://...
# POSTGRES_PRISMA_URL=postgresql://...

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_TOKEN_ENCRYPTION_KEY=

# Mono
MONO_PUBLIC_KEY=
MONO_SECRET_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=
