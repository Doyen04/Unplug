# Better Auth
BETTER_AUTH_SECRET=replace_with_a_random_32_plus_char_secret
BETTER_AUTH_URL=http://localhost:3000

# Production URL — set this in Vercel to your actual domain, e.g. https://unplug-pi.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Neon / Vercel Postgres
# Pooled connection (recommended default)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Direct (unpooled) connection for tooling that needs it
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Optional aliases used by Vercel integrations
# POSTGRES_URL=postgresql://...
# POSTGRES_PRISMA_URL=postgresql://...

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_TOKEN_ENCRYPTION_KEY=

# Mono
MONO_PUBLIC_KEY=
MONO_SECRET_KEY=

# ─── Email (Nodemailer / SMTP) ─────────────────────────────────────────────────
# Option A: provide a full SMTP URL (takes precedence if set)
SMTP_URL=

# Option B: individual SMTP credentials (used when SMTP_URL is not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false        # set to true for port 465
SMTP_USER=
SMTP_PASS=

SMTP_FROM_EMAIL=noreply@unplug.app
SMTP_FROM_NAME=Unplug

# ─── Virtual Cards ─────────────────────────────────────────────────────────────

# Sudo Africa (card issuance)
SUDO_AFRICA_API_KEY=
SUDO_AFRICA_ENV=sandbox                    # change to "production" when live
SUDO_AFRICA_WEBHOOK_SECRET=

# Paystack (Pro billing + wallet funding)
PAYSTACK_SECRET_KEY=sk_test_              # change to sk_live_ when live
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_PRO_PLAN_CODE=PLN_              # copy from Paystack dashboard

# Safe Haven MFB (treasury sweep destination)
SAFE_HAVEN_API_KEY=
UNPLUG_SAFE_HAVEN_ACCOUNT=               # Unplug's own Safe Haven account number
SUDO_SAFE_HAVEN_ACCOUNT=                 # Sudo Africa's Safe Haven pool account

# QStash (background jobs + crons)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
